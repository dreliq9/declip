{
  "version": "1.0",
  "settings": {
    "resolution": [1920, 1080],
    "fps": 30,
    "background": "#000000"
  },
  "timeline": {
    "tracks": [
      {
        "id": "main",
        "clips": [
          {
            "asset": "clip_a.mp4",
            "start": 0,
            "trim_in": 0.5,
            "trim_out": 2.5,
            "filters": [
              {"type": "fade_in", "duration": 0.5}
            ]
          },
          {
            "asset": "clip_b.mp4",
            "start": 2.0,
            "trim_in": 0,
            "trim_out": 2.0,
            "filters": [
              {"type": "fade_out", "duration": 0.5}
            ]
          }
        ]
      }
    ]
  },
  "output": {
    "path": "simple_output.mp4",
    "format": "mp4",
    "codec": "h264",
    "quality": "medium"
  }
}